# Template for .env (gitignored). Copied + populated by platform/deploy.sh
# on first run. Subsequent runs preserve values; only ports are re-derived
# from a fresh port scan.
#
# Hand-editing on the VPS is allowed; just stay aware that deploy.sh
# re-sets the *_HOST_PORT lines via sed.

# ─── Bookmark manager ──────────────────────────────────────────
# SESSION_SECRET and ENCRYPTION_KEY are 32-byte hex strings; generate with:
#   openssl rand -hex 32
# SETUP_CODE_HASH is bcrypt(setup-code, cost=12); see apps/bookmark-manager/README.md
# PUBLIC_URL is the user-facing URL the app is reached at; used for cookie
# scoping and WebAuthn RP origin.
BOOKMARK_SESSION_SECRET=
BOOKMARK_ENCRYPTION_KEY=
BOOKMARK_SETUP_CODE_HASH=
BOOKMARK_PUBLIC_URL=https://negativezero.one/services/bookmark-manager

# ─── Admin ─────────────────────────────────────────────────────
# Platform admin (registration-code generator). Same secret pattern
# as bookmark-manager but no at-rest encryption — admin stores no
# encrypted data, only its own credentials + audit log.
ADMIN_SESSION_SECRET=
ADMIN_SETUP_CODE_HASH=
ADMIN_PUBLIC_URL=https://negativezero.one/services/admin

# ─── TTS (Whisper transcription + LLM cleanup) ─────────────────
# GROQ_API_KEY — get from https://console.groq.com/keys, used for
# Whisper transcription and Llama-based cleanup/proofreading.
# TTS_API_KEY — 32-byte hex generated by deploy.sh; clients (iPhone
# Shortcut, PWA settings) need this to call /api/v1/transcribe.
GROQ_API_KEY=
TTS_API_KEY=

# ─── Host port mapping ─────────────────────────────────────────
# All containers bind to 127.0.0.1 only; nginx fronts them.
# On this shared VPS host ports 3000-3009 are taken by other tenants
# (wellfit, isg); we use 3020+ for apex services.
# deploy.sh re-derives free ports on each run.
LANDING_HOST_PORT=3020
BOOKMARK_HOST_PORT=3021
ADMIN_HOST_PORT=3022
TTS_HOST_PORT=3023
