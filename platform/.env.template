# Template for .env (gitignored). Copied + populated by platform/deploy.sh
# on first run. Subsequent runs preserve values; only ports are re-derived
# from a fresh port scan.
#
# Hand-editing on the VPS is allowed; just stay aware that deploy.sh
# re-sets the *_HOST_PORT lines via sed.

# ─── Bookmark manager ──────────────────────────────────────────
# SESSION_SECRET and ENCRYPTION_KEY are 32-byte hex strings; generate with:
#   openssl rand -hex 32
# SETUP_CODE_HASH is bcrypt(setup-code, cost=12); see apps/bookmark-manager/README.md
# PUBLIC_URL is the user-facing URL the app is reached at; used for cookie
# scoping and WebAuthn RP origin.
BOOKMARK_SESSION_SECRET=
BOOKMARK_ENCRYPTION_KEY=
BOOKMARK_SETUP_CODE_HASH=
BOOKMARK_PUBLIC_URL=https://negativezero.one/services/bookmark-manager

# ─── Admin ─────────────────────────────────────────────────────
# Platform admin (registration-code generator). Same secret pattern
# as bookmark-manager but no at-rest encryption — admin stores no
# encrypted data, only its own credentials + audit log.
ADMIN_SESSION_SECRET=
ADMIN_SETUP_CODE_HASH=
ADMIN_PUBLIC_URL=https://negativezero.one/services/admin

# ─── TTS (Whisper transcription + LLM cleanup) ─────────────────
# GROQ_API_KEY — get from https://console.groq.com/keys, used for
# Whisper transcription and Llama-based cleanup/proofreading.
# TTS_API_KEY — 32-byte hex generated by deploy.sh; clients (iPhone
# Shortcut, PWA settings) need this to call /api/v1/transcribe.
GROQ_API_KEY=
TTS_API_KEY=

# ─── Video downloader (clear-HLS remux) ────────────────────────
# Private passkey-protected service for direct public clear-HLS .m3u8
# downloads, remuxed to .mov/.mp4 with ffmpeg stream copy. Same secret
# pattern as bookmark-manager. SESSION_SECRET + SETUP_CODE_HASH are
# generated by deploy.sh; the MAX_*/CONCURRENCY/TIMEOUT knobs have compose
# defaults and only need setting to override.
VIDEO_DOWNLOADER_SESSION_SECRET=
VIDEO_DOWNLOADER_SETUP_CODE_HASH=
VIDEO_DOWNLOADER_PUBLIC_URL=https://negativezero.one/services/video-downloader
VIDEO_DOWNLOADER_MAX_SEGMENTS=1000
VIDEO_DOWNLOADER_MAX_BYTES=2000000000
VIDEO_DOWNLOADER_CONCURRENCY=4
VIDEO_DOWNLOADER_JOB_TIMEOUT_MS=600000

# ─── Redirector (short-link redirects) ─────────────────────────
# Private passkey-protected service that mints 16-char hash short links
# (…/services/redirector/<hash>) that 302-redirect to a destination URL.
# Same secret pattern as bookmark-manager but no at-rest encryption (targets
# are public redirect destinations). SESSION_SECRET + SETUP_CODE_HASH are
# generated by deploy.sh.
REDIRECTOR_SESSION_SECRET=
REDIRECTOR_SETUP_CODE_HASH=
REDIRECTOR_PUBLIC_URL=https://negativezero.one/services/redirector

# ─── Timezones (cross-timezone meeting planner) ────────────────
# Gated Fastify service: verifies the apex nz_session SSO cookie + admin authz
# and stores per-account presets in SQLite. SSO-cookie-only — no local login,
# so no SESSION_SECRET / SETUP_CODE_HASH; only the public URL is needed.
TIMEZONES_PUBLIC_URL=https://negativezero.one/services/timezones

# ─── SSO (shared single-sign-on session) ──────────────────────
# One HS256 key shared by every service. admin mints an apex-wide `nz_session`
# JWT cookie on passkey login; bookmark-manager / video-downloader / redirector
# / tts all accept it (alongside their own per-service auth as a fallback).
# 32-byte hex, generated by deploy.sh. Rotating it logs everyone out of every
# service.
#
# This same secret doubles as the bearer for the internal per-account
# authorization endpoint (admin's GET /api/internal/authz, reached by the other
# containers at http://admin:3000 — see ADMIN_AUTHZ_URL in docker-compose.yml).
# No separate secret or .env entry is needed for that.
SSO_SESSION_SECRET=

# ─── Host port mapping ─────────────────────────────────────────
# All containers bind to 127.0.0.1 only; nginx fronts them.
# On this shared VPS host ports 3000-3009 are taken by other tenants
# (wellfit, isg); we use 3020+ for apex services.
# deploy.sh re-derives free ports on each run.
LANDING_HOST_PORT=3020
BOOKMARK_HOST_PORT=3021
ADMIN_HOST_PORT=3022
TTS_HOST_PORT=3023
TIMEZONES_HOST_PORT=3024
VIDEO_DOWNLOADER_HOST_PORT=3025
REDIRECTOR_HOST_PORT=3026
