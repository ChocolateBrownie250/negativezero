# Generate via: openssl rand -hex 32
SESSION_SECRET=

# Generate via: openssl rand -hex 32 (32 bytes; encrypts bookmark URLs/names at rest)
ENCRYPTION_KEY=

# Bcrypt hash of the setup code. The plaintext is what you type into the
# "First-time setup" page on first run to register your initial passkey.
# Generate via: docker run --rm node:20-alpine sh -c \
#   'cd /tmp && npm i bcrypt --silent >/dev/null 2>&1 && node -e "require(\"bcrypt\").hash(process.argv[1],12).then(h=>console.log(h))" "yourSetupCodeHere"'
SETUP_CODE_HASH=

# Base URL the app will be reached at. Used to derive WebAuthn RP_ID + origin.
PUBLIC_URL=https://bookmarks.example.com
