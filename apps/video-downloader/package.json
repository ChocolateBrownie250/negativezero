{
  "name": "@negativezero/video-downloader",
  "private": true,
  "version": "1.0.0",
  "description": "Passkey-protected clear-HLS downloader for negativezero",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "build": "npm -w client run build && npm -w server run build",
    "test": "npm -w server run test",
    "start": "npm -w server run start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
