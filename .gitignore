# Secrets — generated at deploy time, never committed
platform/.env
platform/.env.local

# Persistent service state — bind-mounted into containers
platform/data/

# Build / dependency artefacts (per-service .gitignores cover these too;
# duplicated here so they're caught at the root)
node_modules/
dist/
build/

# Python artefacts
__pycache__/
*.py[cod]
.venv/
.pytest_cache/

# Agent tooling — transient git worktrees created by background agents
.claude/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# iCloud Drive sync conflict copies, e.g. "icon 2.svg" / "manifest 2.webmanifest"
# (this repo lives under iCloud Drive on the operator's machine).
* [0-9].*

# Logs
*.log
